---
import { ClientRouter } from "astro:transitions";
import "@/styles/global.css";
import Analytics from "./Analytics.astro";

interface Props {
  title?: string;
}

const { title = "Ara" } = Astro.props;
---

<!doctype html>
<html lang="en" class="bg-neutral-50 dark:bg-neutral-950">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/ara_logo.png" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Merriweather:ital,wght@0,400;0,600;1,400&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <ClientRouter />
    <Analytics />
  </head>
  <body
    class="min-h-screen bg-neutral-50 text-neutral-800 antialiased selection:bg-neutral-200/60 selection:text-neutral-900 dark:bg-neutral-950 dark:text-neutral-100 dark:selection:bg-neutral-700/50 dark:selection:text-neutral-100"
  >
    <header class="border-b border-neutral-200 dark:border-neutral-800">
      <div class="mx-auto flex max-w-3xl items-center justify-between px-6 py-6 md:px-8">
        <div class="flex items-center gap-6">
          <a
            href="/"
            class="inline-flex items-center gap-2 text-sm font-medium tracking-wide text-neutral-900 hover:text-neutral-600 dark:text-neutral-100 dark:hover:text-neutral-300"
          >
            <img src="/ara_logo.png" alt="" class="h-5 w-5" />
            CascadeFund
          </a>
          <nav
            class="hidden items-center gap-4 text-sm text-neutral-600 md:flex dark:text-neutral-500"
            aria-label="Primary navigation"
          >
            <a href="/support" class="hover:text-neutral-900 dark:hover:text-neutral-200">
              Support us
            </a>
          </nav>
        </div>
        <div class="hidden items-center gap-2 md:flex">
          <span class="text-sm text-neutral-600 dark:text-neutral-400">Part of</span>
          <a
            href="https://ara.foundation"
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center gap-2 text-sm font-medium text-neutral-700 underline decoration-neutral-400 underline-offset-4 transition-colors hover:text-neutral-900 dark:text-neutral-300 dark:decoration-neutral-500 dark:hover:text-neutral-100"
          >
            <img src="/ara_logo.png" alt="" class="h-4 w-4" />
            Ara project
          </a>
        </div>
      </div>
      <div class="mx-auto max-w-3xl px-6 pb-5 md:hidden md:px-8">
        <nav class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-neutral-600 dark:text-neutral-500">
          <a href="/support" class="hover:text-neutral-900 dark:hover:text-neutral-200">
            Support us
          </a>
        </nav>
        <div class="mt-3 flex items-center gap-2">
          <span class="text-sm text-neutral-600 dark:text-neutral-400">Part of</span>
          <a
            href="https://ara.foundation"
            target="_blank"
            rel="noreferrer"
            class="inline-flex items-center gap-2 text-sm font-medium text-neutral-700 underline decoration-neutral-400 underline-offset-4 transition-colors hover:text-neutral-900 dark:text-neutral-300 dark:decoration-neutral-500 dark:hover:text-neutral-100"
          >
            <img src="/ara_logo.png" alt="" class="h-4 w-4" />
            Ara project
          </a>
        </div>
      </div>
    </header>
    <main class="minimal-landing-main">
      <slot name="hero" />
      <slot />
    </main>
  </body>
</html>

<style is:global>
  .minimal-landing-main h1,
  .minimal-landing-main h2 {
    font-family: "Merriweather", Georgia, "Times New Roman", serif;
  }
</style>
