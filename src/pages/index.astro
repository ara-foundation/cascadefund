---
export const prerender = false;
import GalaxyLayout from "@/layouts/GalaxyLayout.astro";
import { MenuName } from "@/components/navbar/WorkNavbar.astro";
import StarRpgDialogPanel from "@/components/star/StarRpgDialogPanel";
import CascadeFundHeroTitle from "@/components/cascadefund/CascadeFundHeroTitle";
import CascadeFundAudienceTabs from "@/components/cascadefund/CascadeFundAudienceTabs";
import { HeaderDialogAction } from "@/components/cascadefund/HeaderDialogAction";
---

<GalaxyLayout
    active={MenuName.ProjectName}
    hideLinks={Object.keys(MenuName)}
    hideAuth={true}
    projectName="Cascadefund"
    projectX={0}
    projectY={0}
    projectGalaxies={[]}
>
    <HeaderDialogAction
        type="join"
        dialogList={[]}
        slot="header-actions"
        client:only="react"
    />
    <HeaderDialogAction
        type="add-project"
        dialogList={[]}
        slot="header-actions"
        client:only="react"
    />

    <HeaderDialogAction
        type="join"
        dialogList={[]}
        slot="header-mobile-actions"
        client:only="react"
    />
    <HeaderDialogAction
        type="add-project"
        dialogList={[]}
        slot="header-mobile-actions"
        client:only="react"
    />

    <div
        id="cascadefund-center-stack"
        slot="center"
        class="cfcenter flex w-full flex-col items-center"
    >
        <CascadeFundHeroTitle compact client:only="react" />
        <section
            aria-label="About CascadeFund"
            class="relative z-30 mx-auto w-full max-w-2xl mt-4 space-y-4 px-4 pb-6 text-center pointer-events-none select-none sm:pb-8"
        >
            <!-- <p
                class="text-base leading-relaxed text-slate-600 dark:text-slate-400"
            >
                Massive layoffs are common now. Especially after the AI boom.
                Economic future is unpredictable.
            </p>
            <p
                class="text-base leading-relaxed text-slate-600 dark:text-slate-400"
            >
                Finding a job is hard. Instead, build your own stuff.
                CascadeFund helps you by directly connecting to users.
            </p> -->
            <p
                class="text-base leading-relaxed text-slate-600 dark:text-slate-400"
            >
                An open-source ecosystem of maintainers and users.
            </p>
        </section>
        <CascadeFundAudienceTabs client:only="react" />
    </div>

    <StarRpgDialogPanel
        suppressWhenDeveloperSummaryExpanded={true}
        slot="footer"
        client:only="react"
    />
</GalaxyLayout>

<style is:global>
    #cascadefund-center-stack.cfcenter {
        padding-bottom: min(28rem, 55svh);
    }

    @media (min-width: 640px) {
        #cascadefund-center-stack.cfcenter {
            padding-bottom: min(30rem, 50svh);
        }
    }

    #cascadefund-center-stack.cf-hide-rpg.cfcenter {
        padding-bottom: 1.5rem;
    }

    html,
    body {
        scrollbar-width: none;
        -ms-overflow-style: none;
    }

    html::-webkit-scrollbar,
    body::-webkit-scrollbar {
        display: none;
    }

    * {
        scrollbar-width: none;
        -ms-overflow-style: none;
    }

    *::-webkit-scrollbar {
        display: none;
    }
</style>
