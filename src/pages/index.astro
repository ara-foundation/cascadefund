---
export const prerender = false;
import GalaxyLayout from "@/layouts/GalaxyLayout.astro";
import { MenuName } from "@/components/navbar/WorkNavbar.astro";
import StarRpgDialogPanel from "@/components/star/StarRpgDialogPanel";
import CascadeFundHeroTitle from "@/components/cascadefund/CascadeFundHeroTitle";
---

<GalaxyLayout
    active={MenuName.ProjectName}
    hideLinks={Object.keys(MenuName)}
    hideAuth={true}
    projectName="Cascadefund"
    projectX={0}
    projectY={0}
    projectGalaxies={[]}
>
    <CascadeFundHeroTitle slot="center" client:only="react" />

    <StarRpgDialogPanel slot="footer" client:only="react" />
</GalaxyLayout>

<style is:global>
    html,
    body {
        scrollbar-width: none;
        -ms-overflow-style: none;
    }

    html::-webkit-scrollbar,
    body::-webkit-scrollbar {
        display: none;
    }

    * {
        scrollbar-width: none;
        -ms-overflow-style: none;
    }

    *::-webkit-scrollbar {
        display: none;
    }
</style>
