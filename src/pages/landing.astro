                    />
                  </g>
                  <g transform="translate(545 446)">
                    <image
                      href="https://cdn.simpleicons.org/blender/22c55e"
                      x="0"
                      y="0"
                      width="36"
                      height="36"
                    />
                  </g>
                </g>
              </g>
            </svg>
          </div>
        </div>
      </div>
    </section>
  </section>

  <div
    slot="center"
    class="relative z-20 mx-auto max-w-3xl px-6 pb-24 pt-12 text-left md:px-8 [&_p]:text-pretty [&_li]:text-pretty"
  >
    <section class="mt-12 space-y-8 md:mt-16">
      <h2
        class="text-2xl font-bold leading-tight text-slate-800 md:text-3xl dark:text-slate-200"
      >
        Are you using open-source products?
      </h2>
      <div
        class="space-y-4 text-base leading-relaxed text-slate-600 dark:text-slate-400"
      >
        <p>
          There is a monthly subscription fee for the users. Subscription fee is
          distributed among maintainers across the world. In return, in every
          week, Cascadefund sends your to your email options to direct the apps
          you use.
        </p>
      </div>
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-6">
        <article class="rounded-lg border border-slate-200/20 bg-white/10 px-4 py-3 text-center backdrop-blur-sm dark:border-slate-700/20 dark:bg-slate-900/10 md:col-span-1 lg:col-span-2">
          <svg
            aria-hidden="true"
            viewBox="0 0 24 24"
            class="mx-auto h-12 w-12 text-blue-400"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
          >
            <path d="M12 3 5 6v6c0 4.2 2.6 8 7 9 4.4-1 7-4.8 7-9V6z"></path>
            <path d="m9.5 12 1.8 1.8L15 10"></path>
          </svg>
          <h3
            class="mt-3 text-base font-semibold text-slate-800 dark:text-slate-200"
          >
            Prevent breaking changes
          </h3>
          <p
            class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-400"
          >
            Can you be sure tech giants won't make you adapt to them?
          </p>
        </article>
        <article class="rounded-lg border border-slate-200/20 bg-white/10 px-4 py-3 text-center backdrop-blur-sm dark:border-slate-700/20 dark:bg-slate-900/10 md:col-span-1 lg:col-span-2">
          <svg
            aria-hidden="true"
            viewBox="0 0 24 24"
            class="mx-auto h-12 w-12 text-blue-400"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
          >
            <path
              d="M9 14a4 4 0 1 1 6 0l-1.1.8A2.5 2.5 0 0 0 13 16.8V18h-2v-1.2a2.5 2.5 0 0 0-.9-2z"
            ></path>
            <path d="M10 21h4"></path>
            <path d="m14 5 4-2"></path>
          </svg>
          <h3
            class="mt-3 text-base font-semibold text-slate-800 dark:text-slate-200"
          >
            Suggest new features
          </h3>
          <p
            class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-400"
          >
            Will tech giants listen to you?
          </p>
        </article>
        <article class="rounded-lg border border-slate-200/20 bg-white/10 px-4 py-3 text-center backdrop-blur-sm dark:border-slate-700/20 dark:bg-slate-900/10 md:col-span-2 lg:col-span-2">
          <svg
            aria-hidden="true"
            viewBox="0 0 24 24"
            class="mx-auto h-12 w-12 text-blue-400"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
          >
            <path d="M7 9h3V6h4v3h3v4h-3v3h-4v-3H7z"></path>
            <path d="m4 17 4-4"></path>
            <path d="m16 11 4-4"></path>
          </svg>
          <h3
            class="mt-3 text-base font-semibold text-slate-800 dark:text-slate-200"
          >
            Plug-in compatible apps with your open-source stack
          </h3>
          <p
            class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-400"
          >
            Tech giants will "kill" you for that.
          </p>
        </article>
        <article
          class="rounded-lg border border-slate-200/20 bg-white/10 px-4 py-3 text-center backdrop-blur-sm dark:border-slate-700/20 dark:bg-slate-900/10 md:col-span-1 lg:col-span-2 lg:col-start-2"
        >
          <svg
            aria-hidden="true"
            viewBox="0 0 24 24"
            class="mx-auto h-12 w-12 text-blue-400"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
          >
            <path d="M4 19c1.8-3.8 4.4-6 8-6s6.2 2.2 8 6"></path>
            <path d="M7 13c.2-3 1.9-5 5-5s4.8 2 5 5"></path>
            <path d="M10 8c.2-2 1.3-3 2-3s1.8 1 2 3"></path>
          </svg>
          <h3
            class="mt-3 text-base font-semibold text-slate-800 dark:text-slate-200"
          >
            3 apps or 3 million apps, same subscription
          </h3>
          <p
            class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-400"
          >
            Your subscription grows Amazon forest. Tech giants build walled
            gardens.
          </p>
        </article>
        <article
          class="rounded-lg border border-slate-200/20 bg-white/10 px-4 py-3 text-center backdrop-blur-sm dark:border-slate-700/20 dark:bg-slate-900/10 md:col-span-2 lg:col-span-2 lg:col-start-4"
        >
          <svg
            aria-hidden="true"
            viewBox="0 0 24 24"
            class="mx-auto h-12 w-12 text-blue-400"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
          >
            <path d="m12 3 1.8 4.2L18 9l-4.2 1.8L12 15l-1.8-4.2L6 9l4.2-1.8z"
            ></path>
            <path d="M19 15v6"></path>
            <path d="M16 18h6"></path>
          </svg>
          <h3 class="text-base font-semibold text-slate-800 dark:text-slate-200">
            Start using Open Source
          </h3>
          <p
            class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-400"
          >
            Email will be sent to you when subscription will be available.
          </p>
          <button
            type="button"
            data-open-dialog="join-waitlist-modal"
            class="mt-4 inline-flex items-center justify-center rounded-lg border border-slate-300/40 bg-slate-900/50 px-5 py-2.5 text-sm font-semibold text-slate-100 backdrop-blur-sm transition-colors hover:border-sky-400/50 hover:bg-slate-800/60 dark:border-slate-600/50 dark:bg-slate-950/40 dark:text-slate-100 dark:hover:border-sky-400/40 dark:hover:bg-slate-900/60"
          >
            Join waitlist
          </button>
        </article>
      </div>
    </section>

    <section class="mt-12 space-y-8 md:mt-16">
      <div class="mx-auto max-w-3xl space-y-4 text-center">
        <h2
          class="text-2xl font-bold leading-tight text-slate-800 md:text-3xl dark:text-slate-200"
        >
          Are you maintaining an open-source project?
        </h2>
        <p
          class="text-base leading-relaxed text-slate-600 dark:text-slate-400"
        >
          To make a semantic web, all projects agree on a user-centric protocol
          which means received user funds can be used for:
        </p>
      </div>

      <div class="mx-auto flex w-full max-w-3xl flex-col gap-4">
        <article
          class="rounded-lg border border-slate-200/20 bg-white/10 p-5 backdrop-blur-sm dark:border-slate-700/20 dark:bg-slate-900/10"
        >
          <div class="flex items-center justify-between gap-3">
            <h3
              class="text-base font-semibold text-slate-800 dark:text-slate-200"
            >
              User-centric rule 1
            </h3>
            <svg
              aria-hidden="true"
              viewBox="0 0 24 24"
              class="h-6 w-6 shrink-0 text-blue-400"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
