---
import Layout from "@/layouts/PanelViewLayout.astro";
import { MenuName } from "@/components/navbar/WorkNavbar.astro";
import Space from "@/components/all-stars/Space";
import { mockUserStars } from "@/types/mock-data";
import AddProjectModal from "@/components/cascadefund/AddProjectModal.astro";
import JoinWaitlistModal from "@/components/cascadefund/JoinWaitlistModal.astro";
---

<Layout
  hideLinks={Object.keys(MenuName)}
  hideAuth={true}
  title="Cascadefund"
>
  <div
    class="fixed top-0 left-0 w-screen h-screen z-10 pointer-events-none"
    id="galaxy-space"
    style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; transform-origin: center center;"
  >
    <Space
      client:only="react"
      users={mockUserStars}
      className="z-10"
      projectGalaxies={[]}
    />
  </div>

  <section slot="hero" class="relative z-20 w-full">
    <section
      class="hero-cascade-bg relative flex min-h-[75vh] w-full items-center overflow-hidden bg-slate-950/35 backdrop-blur-[2px]"
    >
      <div
        class="pointer-events-none absolute -top-20 -right-16 h-56 w-56 rounded-full bg-cyan-400/15 blur-3xl"
      >
      </div>
      <div
        class="pointer-events-none absolute -bottom-24 -left-20 h-64 w-64 rounded-full bg-violet-500/15 blur-3xl"
      >
      </div>

      <div class="mx-auto w-full max-w-6xl px-6 py-12 md:px-8 md:py-16">
        <div
          class="grid items-center gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(360px,500px)]"
        >
          <div class="space-y-8">
            <h1
              class="text-4xl font-bold leading-tight text-transparent md:text-5xl md:leading-tight bg-gradient-to-r from-sky-300 via-cyan-200 to-violet-300 bg-clip-text bg-[length:300%_100%] animate-gradient"
            >
              Cascadefund
            </h1>
            <div
              class="max-w-3xl space-y-4 text-base leading-relaxed text-slate-600 dark:text-slate-400"
            >
              <p>
                Google, Apple, Facebook... tech giants are coherent ecosystems
                with the dozens of the apps and services.
              </p>
              <p>
                Open-source is not. Their only marketing is "open-source
                alternative", lacks polished UX, incompatible with each other
                and <strong>unsustainable</strong>.
              </p>
              <p>
                Cascadefund changes this by forming a semantic web of
                open-source. The goal is maintainer's sustainability, reduced
                OSS complexity and increased OSS popularity.
              </p>
            </div>
            <p
              class="max-w-3xl rounded-lg border border-slate-200/20 bg-white/10 px-4 py-3 text-xl font-semibold leading-relaxed text-transparent backdrop-blur-sm md:text-2xl bg-gradient-to-r from-sky-300 via-cyan-200 to-violet-300 bg-clip-text dark:border-slate-700/30 dark:bg-slate-900/20"
            >
              We are onboarding the first projects. Join us, to turn the web
              into an open-source ecosystem.
            </p>
            <button
              type="button"
              data-open-dialog="add-project-modal"
              class="inline-flex items-center justify-center rounded-lg border border-slate-300/40 bg-slate-900/50 px-6 py-3 text-sm font-medium text-slate-100 backdrop-blur-sm transition-colors hover:border-sky-400/50 hover:bg-slate-800/60 dark:border-slate-600/50 dark:bg-slate-950/40 dark:text-slate-100 dark:hover:border-sky-400/40 dark:hover:bg-slate-900/60"
            >
              Add your project
            </button>
          </div>

          <div class="hero-network flex justify-center lg:justify-end">
            <svg
              viewBox="0 0 600 500"
              class="h-auto w-full max-w-[600px]"
              role="img"
              aria-label="Connected big-tech app ecosystems contrasted with scattered open-source tools"
            >
              <defs>
                <style>
                  .diagram-text {
                    font-family: Inter, ui-sans-serif, system-ui, sans-serif;
                  }
                </style>
              </defs>

              <g class="connectors">
                <line x1="100" y1="66" x2="208" y2="66"></line>
                <line x1="100" y1="66" x2="258" y2="66"></line>
                <line x1="100" y1="66" x2="308" y2="66"></line>
                <line x1="100" y1="66" x2="358" y2="66"></line>
                <line x1="100" y1="66" x2="408" y2="66"></line>
                <line x1="100" y1="66" x2="458" y2="66"></line>
                <line x1="100" y1="152" x2="208" y2="152"></line>
                <line x1="100" y1="152" x2="258" y2="152"></line>
                <line x1="100" y1="152" x2="308" y2="152"></line>
                <line x1="100" y1="152" x2="358" y2="152"></line>
                <line x1="100" y1="152" x2="408" y2="152"></line>
                <line x1="100" y1="152" x2="458" y2="152"></line>
                <line x1="100" y1="238" x2="208" y2="238"></line>
                <line x1="100" y1="238" x2="258" y2="238"></line>
                <line x1="100" y1="238" x2="308" y2="238"></line>
                <line x1="100" y1="238" x2="358" y2="238"></line>
                <line x1="100" y1="238" x2="408" y2="238"></line>
                <line x1="100" y1="238" x2="458" y2="238"></line>
                <line x1="100" y1="324" x2="208" y2="324"></line>
                <line x1="100" y1="324" x2="258" y2="324"></line>
                <line x1="100" y1="324" x2="308" y2="324"></line>
                <line x1="100" y1="324" x2="358" y2="324"></line>
                <line x1="100" y1="324" x2="408" y2="324"></line>
                <line x1="100" y1="324" x2="458" y2="324"></line>
              </g>

              <g class="row-dim row-google">
                <text x="26" y="74" class="diagram-text company-label"
                  >Google</text
                >
                <image
                  class="company-logo"
                  href="https://cdn.simpleicons.org/google"
                  x="72"
                  y="52"
                  width="28"
                  height="28"
                />
                <g class="app-bases">
                  <rect x="206" y="50" width="32" height="32" rx="10"></rect>
                  <rect x="256" y="50" width="32" height="32" rx="10"></rect>
                  <rect x="306" y="50" width="32" height="32" rx="10"></rect>
                  <rect x="356" y="50" width="32" height="32" rx="10"></rect>
                  <rect x="406" y="50" width="32" height="32" rx="10"></rect>
                  <rect x="456" y="50" width="32" height="32" rx="10"></rect>
                </g>
                <g class="small-app">
                  <image
                    href="https://cdn.simpleicons.org/gmail"
                    x="208"
                    y="52"
                    width="28"
                    height="28"
                  />
                  <image
                    href="https://cdn.simpleicons.org/googledrive"
                    x="258"
