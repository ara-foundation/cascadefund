                    x="258"
                    y="138"
                    width="28"
                    height="28"
                  />
                  <image
                    href="https://cdn.simpleicons.org/imessage"
                    x="308"
                    y="138"
                    width="28"
                    height="28"
                  />
                  <image
                    href="https://img.icons8.com/color/48/facetime.png"
                    x="358"
                    y="138"
                    width="28"
                    height="28"
                  />
                  <image
                    href="https://cdn.simpleicons.org/icloud"
                    x="408"
                    y="138"
                    width="28"
                    height="28"
                  />
                  <image
                    href="https://cdn.simpleicons.org/applemusic"
                    x="458"
                    y="138"
                    width="28"
                    height="28"
                  />
                </g>
              </g>

              <g class="row-dim row-microsoft">
                <text x="10" y="246" class="diagram-text company-label"
                  >Microsoft</text
                >
                <image
                  class="company-logo"
                  href="https://img.icons8.com/color/48/microsoft.png"
                  x="72"
                  y="224"
                  width="28"
                  height="28"
                />
                <g class="app-bases">
                  <rect x="206" y="222" width="32" height="32" rx="10"></rect>
                  <rect x="256" y="222" width="32" height="32" rx="10"></rect>
                  <rect x="306" y="222" width="32" height="32" rx="10"></rect>
                  <rect x="356" y="222" width="32" height="32" rx="10"></rect>
                  <rect x="406" y="222" width="32" height="32" rx="10"></rect>
                  <rect x="456" y="222" width="32" height="32" rx="10"></rect>
                </g>
                <g class="small-app">
                  <image
                    href="https://img.icons8.com/color/48/azure-1.png"
                    x="208"
                    y="224"
                    width="28"
                    height="28"
                  />
                  <image
                    href="https://img.icons8.com/color/48/xbox.png"
                    x="258"
                    y="224"
                    width="28"
                    height="28"
                  />
                  <image
                    href="https://img.icons8.com/color/48/microsoft-outlook-2019.png"
                    x="308"
                    y="224"
                    width="28"
                    height="28"
                  />
                  <image
                    href="https://img.icons8.com/color/48/microsoft-teams.png"
                    x="358"
                    y="224"
                    width="28"
                    height="28"
                  />
                  <image
                    href="https://img.icons8.com/color/48/microsoft-onedrive-2019.png"
                    x="408"
                    y="224"
                    width="28"
                    height="28"
                  />
                  <image
                    href="https://img.icons8.com/color/48/windows-11.png"
                    x="458"
                    y="224"
                    width="28"
                    height="28"
                  />
                </g>
              </g>

              <g class="row-dim row-meta">
                <text x="27" y="332" class="diagram-text company-label"
                  >Meta</text
                >
                <image
                  class="company-logo"
                  href="https://cdn.simpleicons.org/meta"
                  x="72"
                  y="310"
                  width="28"
                  height="28"
                />
                <g class="app-bases">
                  <rect x="206" y="308" width="32" height="32" rx="10"></rect>
                  <rect x="256" y="308" width="32" height="32" rx="10"></rect>
                  <rect x="306" y="308" width="32" height="32" rx="10"></rect>
                  <rect x="356" y="308" width="32" height="32" rx="10"></rect>
                  <rect x="406" y="308" width="32" height="32" rx="10"></rect>
                  <rect x="456" y="308" width="32" height="32" rx="10"></rect>
                </g>
                <g class="small-app">
                  <image
                    href="https://cdn.simpleicons.org/facebook"
                    x="208"
                    y="310"
                    width="28"
                    height="28"
                  />
                  <image
                    href="https://cdn.simpleicons.org/instagram"
                    x="258"
                    y="310"
                    width="28"
                    height="28"
                  />
                  <image
                    href="https://cdn.simpleicons.org/messenger"
                    x="308"
                    y="310"
                    width="28"
                    height="28"
                  />
                  <image
                    href="https://cdn.simpleicons.org/threads"
                    x="358"
                    y="310"
                    width="28"
                    height="28"
                  />
                  <image
                    href="https://cdn.simpleicons.org/whatsapp"
                    x="408"
                    y="310"
                    width="28"
                    height="28"
                  />
                  <g transform="translate(458 310)">
                    <rect x="0" y="0" width="28" height="28" rx="7"></rect>
                    <ellipse cx="14" cy="14" rx="8.5" ry="5.5"></ellipse>
                    <circle cx="10.5" cy="14" r="1.1"></circle>
                    <circle cx="17.5" cy="14" r="1.1"></circle>
                  </g>
                </g>
              </g>

              <g class="row-os">
                <text x="30" y="432" class="diagram-text os-label">OSS</text>
                <image
                  href="/ara_logo.png"
                  x="72"
                  y="408"
                  width="28"
                  height="28"
                />

                <g class="os-app">
                  <g transform="translate(210 400)">
                    <rect
                      x="0"
                      y="0"
                      width="36"
                      height="36"
                      rx="8"
                      class="os-placeholder-icon"></rect>
                    <path d="M18 10v16M10 18h16" class="os-placeholder-mark"
                    ></path>
                    <text x="-8" y="52" class="diagram-text os-placeholder-text"
                      >Your project</text
                    >
                  </g>
                  <g transform="translate(286 448)">
                    <image
                      href="https://cdn.simpleicons.org/firefox/22c55e"
                      x="0"
                      y="0"
                      width="36"
                      height="36"
                    />
                  </g>
                  <g transform="translate(352 390)">
                    <image
                      href="https://cdn.simpleicons.org/vlcmediaplayer/22c55e"
                      x="0"
